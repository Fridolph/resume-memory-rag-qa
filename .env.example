# Chat 模型：OpenAI-compatible 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=

# DeepSeek v4 专用入口：pnpm run ask:v7:dpv4
# 只影响回答生成，不影响 embedding
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=deepseek-v4-flash

# 向量模型地址：必须和写入 Milvus 时的 embedding 模型一致
# 如果只是替换 Chat 模型，不要随手改 embedding，否则需要全量重建向量库
# 注意：DeepSeek 官方 API 目前没有 embeddings 端点，不能用 https://api.deepseek.com 作为 EMBEDDINGS_URL
# 只要配置 EMBEDDINGS_URL / EMBEDDINGS_BASE_URL，就必须配置 EMBEDDINGS_API_KEY
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=
EMBEDDINGS_URL=
EMBEDDINGS_MODEL_NAME=
JWT_SECRET=
AMAP_MAPS_API_KEY=
